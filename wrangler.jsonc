{
	"main": "dist/_worker.js/index.js",
	"name": "discover-puertorico",
  "compatibility_date": "2026-02-04",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "trip-planner-cache-pr",
      "database_id": "08172971-c2bf-453f-8f0d-4742c036c98b"
    }
  ]
}
